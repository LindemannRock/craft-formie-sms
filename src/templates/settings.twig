{% import '_includes/forms' as forms %}

{% if settings is defined and settings.hasErrors() %}
    {{ include('lindemannrock-base/_partials/error-summary', {
        errors: settings.getErrors(),
        translationCategory: 'formie-sms',
        linkMode: 'field-id',
    }) }}
{% endif %}

<h2 class="first">{{ 'General Settings'|t('formie-sms') }}</h2>

{{ forms.textField({
    label: 'Plugin Name'|t('formie-sms'),
    instructions: 'The name of the plugin as it appears in the Control Panel menu'|t('formie-sms'),
    id: 'pluginName',
    name: 'pluginName',
    value: settings.pluginName,
    required: true,
    warning: settings.isOverriddenByConfig('pluginName') ? 'This is being overridden by the `pluginName` setting in the `config/formie-sms.php` file.'|t('formie-sms'),
    disabled: settings.isOverriddenByConfig('pluginName'),
    errors: settings.getErrors('pluginName'),
}) }}

<hr>

<h2>{{ 'SMS Manager Integration'|t('formie-sms') }}</h2>

<p class="light">
    {{ 'This plugin integrates with {link} to send SMS notifications when forms are submitted.'|t('formie-sms', {
        link: '<a href="' ~ url('sms-manager') ~ '">SMS Manager</a>'
    })|raw }}
</p>

<p class="light">
    {{ 'Configure your SMS providers and sender IDs in SMS Manager, then use this integration in your Formie forms.'|t('formie-sms') }}
</p>

{% include 'lindemannrock-base/_components/plugin-credit' %}
