{% import '_includes/forms' as forms %}

{% set handle = integration.handle %}
{% set formSettings = integration.getFormSettings().getSettings() %}

{# `senderIdHandle` is the new (3.10+) authoritative field — empty string is
   the "Use SMS Manager default" sentinel; non-empty is a specific handle.
   `initialSenderIdHandle` is pre-resolved by PHP so legacy forms (storing
   only `senderIdId` int) still pre-select the correct dropdown option. #}
{% set language = form.settings.integrations[handle].language ?? 'any' %}

{% set settingsValues = {
    senderIdHandle: initialSenderIdHandle,
    recipients: form.settings.integrations[handle].recipients ?? '',
    message: form.settings.integrations[handle].message ?? '',
    language: language,
}|json_encode %}

<integration-form-settings
    :form-settings="{{ formSettings|json_encode }}"
    :values="{{ settingsValues }}"
    handle="{{ handle }}"
>
    <template v-slot="{ get, isEmpty, input, settings, sourceId, loading, refresh, error, errorMessage, getSourceFields, model }">

        {# Sender ID — single dropdown with provider grouping via <optgroup>.
           First option (when SMS Manager has a default configured) is the
           "Use SMS Manager default" sentinel (empty value). Specific senders
           follow, grouped by their provider. Picking a sender from any
           provider works because dispatch derives the provider from the
           sender's `providerHandle` automatically. #}
        {{ forms.selectField({
            label: 'Sender ID'|t('formie-sms'),
            instructions: 'Senders are grouped by their provider. Pick "Use SMS Manager default" to follow whatever is configured plugin-wide; pick a specific sender to pin this form to that sender regardless of future default changes.'|t('formie-sms'),
            name: 'senderIdHandle',
            id: 'senderIdHandle',
            value: initialSenderIdHandle,
            options: senderIdOptions,
        }) }}

        <ul class="errors" v-cloak v-if="!isEmpty(get(form, 'settings.integrations.{{ handle }}.errors.senderIdHandle'))">
            <li :key="index" v-for="(error, index) in get(form, 'settings.integrations.{{ handle }}.errors.senderIdHandle')">
                ${ error }
            </li>
        </ul>

        {# Recipients #}
        <form-kit
            :buttons="['variableTag']"
            :required="true"
            help="{{ 'Use a comma-separated list for multiple recipients. Prefer the {phone} variable over {phoneNumber} — it produces a full international (E.164) number that works with all SMS providers.'|t('formie-sms', {phone: '{field:phone}', phoneNumber: '{field:phone.number}'}) }}"
            label="{{ 'Recipient(s)'|t('formie-sms') }}"
            rows="1"
            type="richText"
            v-model="model.recipients"
            variables="plainTextVariables"
        ></form-kit>

        <input type="hidden" name="recipients" :value="model.recipients" />

        <ul class="errors" v-cloak v-if="!isEmpty(get(form, 'settings.integrations.{{ handle }}.errors.recipients'))">
            <li :key="index" v-for="(error, index) in get(form, 'settings.integrations.{{ handle }}.errors.recipients')">
                ${ error }
            </li>
        </ul>

        {# Message #}
        <form-kit
            :buttons="['variableTag', 'align-left', 'align-right', 'undo', 'redo']"
            :required="true"
            help="{{ 'The SMS message content. Use form field variables to personalize.'|t('formie-sms') }}"
            label="{{ 'Message'|t('formie-sms') }}"
            type="richText"
            v-model="model.message"
            variables="plainTextVariables"
        ></form-kit>

        <input type="hidden" name="message" :value="model.message" />

        <ul class="errors" v-cloak v-if="!isEmpty(get(form, 'settings.integrations.{{ handle }}.errors.message'))">
            <li :key="index" v-for="(error, index) in get(form, 'settings.integrations.{{ handle }}.errors.message')">
                ${ error }
            </li>
        </ul>

        {# Language Filter #}
        {{ forms.selectField({
            label: 'Language Filter'|t('formie-sms'),
            instructions: 'Only send SMS when the form is submitted from a specific language site.'|t('formie-sms'),
            name: 'language',
            id: 'language',
            value: language,
            required: true,
            options: languages,
        }) }}

    </template>
</integration-form-settings>

{% set languageDropdown = 'language'|namespaceInputName %}
{% set messageInput = 'message'|namespaceInputName %}

{% js %}
$(function() {
    // RTL direction for the Message rich-text editor when the language
    // filter is Arabic. (The sender dropdown no longer needs JS — Craft's
    // native optgroup rendering handles the provider grouping.)
    function checkDirection() {
        var language = $("[name='{{ languageDropdown }}']").val();
        var $richText = $("[name='{{ messageInput }}']").closest("div").find(".fui-rich-text");
        if (language === 'ar') {
            $richText.css({"direction": "rtl"});
        } else {
            $richText.css({"direction": "ltr"});
        }
    }

    $("[name='{{ languageDropdown }}']").on('change', checkDirection);
    checkDirection();
});
{% endjs %}
